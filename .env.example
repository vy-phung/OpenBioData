# Required to run the app at all.
ANTHROPIC_API_KEY=

# Optional Gemini fallback, used if the Anthropic call fails. The code checks
# these three names in order (NEW_GOOGLE_API_KEY, then GOOGLE_API_KEY, then
# NEW_GEMINI_API) and uses whichever is set first -- you only need one.
NEW_GOOGLE_API_KEY=
GOOGLE_API_KEY=
NEW_GEMINI_API=

# --- Everything below is optional. The app runs without it; each integration
# is skipped gracefully (with a warning) if its variables are unset. ---

# Google service account credentials (as a single-line JSON string) for the
# hosted app's Google Sheets/Drive backend -- usage tracking, extraction
# cache, and feedback logging. Not needed for local/self-hosted single-user
# use.
GCP_CREDS_JSON=

# Google Drive folder ID where per-sample data docs are stored. Only used
# alongside GCP_CREDS_JSON.
GDRIVE_DATA_FOLDER_NAME=

# GeoNames account (https://www.geonames.org/login) used to standardize
# free-text locations to country names. Skipped if unset.
URL_SEARCHJSON=
URL_COUNTRYJSON=
USERNAME_GEO=

# NCBI E-utilities: an API key raises the request-rate limit, and NCBI_EMAIL
# identifies the caller per NCBI's usage policy. Both optional.
NCBI_API_KEY=
NCBI_EMAIL=

# Serper.dev API key for web-search fallback when locating papers/accessions.
SERPER_API_KEY=

# Elsevier ScienceDirect API key, used to fetch full text from
# ScienceDirect-hosted papers.
SCIENCE_DIRECT_API=

# PORT is intentionally not listed here -- hosting platforms (e.g. Railway)
# set it automatically, and api.py already defaults to 8000 locally. Setting
# it to an empty value here would override that default with an empty
# string and crash the app on startup.

# Set to "true" to skip real LLM calls and return placeholder "unknown"
# values -- useful for testing the pipeline without spending API credits.
SKIP_LLM_API=
